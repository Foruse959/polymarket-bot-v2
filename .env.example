# ═══════════════════════════════════════════════════════════════
# 5MIN_TRADE v2.2 Beast Mode — Environment Configuration
# Polymarket V2 (April 2026) — pUSD Collateral
# ═══════════════════════════════════════════════════════════════

# ── TELEGRAM BOT ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── POLYMARKET WALLET (for LIVE trading) ──
# Private key — needed to sign orders
POLY_PRIVATE_KEY=0x_your_private_key_here

# Signature type: 0=EOA/MetaMask, 1=Magic/Email, 2=Proxy wallet
POLY_SIGNATURE_TYPE=0

# For proxy wallets (sig_type=2) ONLY:
POLY_PROXY_WALLET=
POLY_FUNDER_ADDRESS=

# ── MANUAL CLOB API CREDS (optional, skip if wallet is enabled on polymarket.com) ──
# If you get "Could not create api key" error, EITHER:
#   (a) Enable trading on polymarket.com by connecting wallet and signing
#   (b) Set these 3 from polymarket.com → Settings → API
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ── BUILDER (for order attribution, optional) ──
POLY_BUILDER_CODE=
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# ── TRADING MODE ──
# paper = simulated trading, live = real orders on Polymarket
TRADING_MODE=paper
STARTING_BALANCE=100.0

# ── COINS (can also be edited via Telegram /coins command at runtime) ──
# Supported: BTC, ETH, SOL, XRP
ENABLED_COINS=BTC,ETH,SOL,XRP
ENABLED_TIMEFRAMES=5,15

# ── RELAY (bypass geo-restrictions if needed) ──
CLOB_RELAY_URL=
CLOB_RELAY_AUTH_TOKEN=

# ── RISK MANAGEMENT ──
MAX_DAILY_LOSS_PCT=50.0
MAX_TOTAL_POSITIONS=20
KELLY_FRACTION=0.25
KELLY_MAX_BET_PCT=0.08
DRAWDOWN_HALT_PCT=25.0
CONSECUTIVE_LOSS_HALT=8
STRICT_MIN_CONFIDENCE=0.55

# ── ADVANCED ──
POLYGON_RPC_URL=https://polygon-rpc.com
POLY_CHAIN_ID=137
DASHBOARD_PORT=8080
