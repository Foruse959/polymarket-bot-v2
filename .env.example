# 5min_trade v2 — Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# REQUIRED: Telegram Bot
# ═══════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ═══════════════════════════════════════════════════════════════════
# REQUIRED for LIVE trading: Polymarket Wallet
# ═══════════════════════════════════════════════════════════════════
# Private key (with 0x prefix)
POLY_PRIVATE_KEY=0x1234567890abcdef...

# Signature type: 0=EOA/MetaMask, 1=Email/Magic, 2=Proxy
POLY_SIGNATURE_TYPE=0

# For proxy wallets (sig_type=2): Set the proxy/maker wallet address
POLY_PROXY_WALLET=0x...

# Optional: Explicit funder address (auto-derived if blank)
# POLY_FUNDER_ADDRESS=0x...

# Optional: Gnosis Safe address for multi-sig
# POLY_SAFE_ADDRESS=0x...

# ═══════════════════════════════════════════════════════════════════
# TRADING MODE
# ═══════════════════════════════════════════════════════════════════
TRADING_MODE=paper
LIVE_RISK_MODE=concentration
STARTING_BALANCE_USDC=100.0

# Order preference: maker (limit orders) or taker (market orders)
DEFAULT_ORDER_TYPE=maker
MAKER_PREFERRED=true

# ═══════════════════════════════════════════════════════════════════
# MAKER STRATEGY SETTINGS
# ═══════════════════════════════════════════════════════════════════
MAKER_MIN_SPREAD_BPS=50
MAKER_TARGET_SPREAD_BPS=100
MAKER_MAX_SPREAD_BPS=300
LONGSHOT_THRESHOLD_LOW=0.20
LONGSHOT_THRESHOLD_HIGH=0.80
LONGSHOT_MAX_POSITION_USDC=50.0

# ═══════════════════════════════════════════════════════════════════
# MARKETS & COINS
# ═══════════════════════════════════════════════════════════════════
ENABLED_COINS=BTC,ETH
ENABLED_TIMEFRAMES=5,15

# ═══════════════════════════════════════════════════════════════════
# NETWORK & PROXY
# ═══════════════════════════════════════════════════════════════════
POLY_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com

# Proxy for bypassing geo-blocks
# PROXY_URL=http://user:pass@host:port

# CLOB Relay (alternative to proxy)
# CLOB_RELAY_URL=https://your-relay.com
# CLOB_RELAY_AUTH_TOKEN=your_token

# ═══════════════════════════════════════════════════════════════════
# BUILDER RELAYER (optional, for gasless transactions)
# ═══════════════════════════════════════════════════════════════════
# POLY_BUILDER_API_KEY=...
# POLY_BUILDER_SECRET=...
# POLY_BUILDER_PASSPHRASE=...
AUTO_REDEEM_INTERVAL=120

# ═══════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════
DATABASE_PATH=data/trades.db
