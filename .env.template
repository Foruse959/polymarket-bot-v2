# ==========================================
# POLYMARKET TRADING BOT - ENVIRONMENT CONFIG
# ==========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ==========================================
# TELEGRAM (For notifications)
# ==========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ==========================================
# POLYMARKET WALLET (REQUIRED for live trading)
# ==========================================
# Your private key (with 0x prefix)
# WARNING: Keep this SECRET! Never share!
POLY_PRIVATE_KEY=0xyour_private_key_here

# Your wallet address (auto-derived if blank)
POLY_PROXY_WALLET=0xyour_proxy_wallet_here

# Signature type: 0=EOA, 1=Magic, 2=Proxy, 3=Deposit (V2)
POLY_SIGNATURE_TYPE=0

# Chain ID: 137=Polygon Mainnet
POLY_CHAIN_ID=137

# ==========================================
# CLOB API (Auto-derived from private key if blank)
# ==========================================
POLY_API_KEY=your_api_key
POLY_API_SECRET=your_api_secret
POLY_PASSPHRASE=your_passphrase

# ==========================================
# BUILDER PROGRAM (Optional - for fee discounts)
# ==========================================
# Get from: https://polymarket.com/builders
POLY_BUILDER_API_KEY=your_builder_key
POLY_BUILDER_SECRET=your_builder_secret
POLY_BUILDER_PASSPHRASE=your_builder_passphrase

# ==========================================
# TRADING MODE
# ==========================================
# 'paper' = fake money (test)
# 'live' = real money (production)
TRADING_MODE=paper

# Starting balance for paper trading
STARTING_BALANCE=1.5

# Risk mode: seed, plant, concentration, medium, aggressive
LIVE_RISK_MODE=seed

# ==========================================
# RPC & PROXY (Optional)
# ==========================================
# Custom Polygon RPC (optional)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# HTTP/SOCKS proxy for geoblock bypass (if needed)
PROXY_URL=

# CLOB Relay for geoblock bypass (recommended)
CLOB_RELAY_URL=
CLOB_RELAY_AUTH_TOKEN=

# ==========================================
# STRATEGY SETTINGS
# ==========================================
# Coins to trade: BTC,ETH,SOL
ENABLED_COINS=BTC,ETH

# Timeframes: 5,15,30
ENABLED_TIMEFRAMES=5,15

# Minimum edge after fees (0.03 = 3 cents)
MIN_EDGE_AFTER_FEES=0.03

# ==========================================
# RISK LIMITS (SEED MODE - For $1.5 balance)
# ==========================================
# Max positions: 2 (SEED mode)
MAX_POSITIONS=2

# Min confidence: 0.90 (very high for SEED)
MIN_CONFIDENCE=0.90

# Position size: 20% of balance max
MAX_BET_PCT=20

# Stop loss: 10% for SEED
STOP_LOSS_PCT=10

# ==========================================
# SAFETY SWITCHES
# ==========================================
# Set to 'false' to disable
ENABLE_ARB=true
ENABLE_TIME_DECAY=true
ENABLE_SPREAD_SCALPER=true
# Momentum disabled (weak in backtest)
ENABLE_MOMENTUM=false

# ==========================================
# AUTO-REDEEM (Gasless)
# ==========================================
AUTO_REDEEM_INTERVAL=120

# ==========================================
# ADVANCED (Don't change unless you know)
# ==========================================
USE_FOK_ORDERS=true
TAKER_FEE_RATE=0.03125

# ==========================================
# HOW TO GET THESE VALUES:
# ==========================================
# 1. TELEGRAM_BOT_TOKEN: Talk to @BotFather on Telegram
# 2. TELEGRAM_CHAT_ID: Message @userinfobot on Telegram  
# 3. POLY_PRIVATE_KEY: From your MetaMask/Polymarket wallet
#    - Export private key (KEEP SECRET!)
# 4. BUILDER API: Apply at https://polymarket.com/builders
# 5. PROXY: Use if geoblocked (try without first)
#
# SECURITY WARNINGS:
# - Never share private key
# - Never commit .env file
# - Use paper mode first
# - Start with small amounts